---
import Layout from '@/layouts/Layout.astro';
import { Button } from "@/components/ui/button";
import { Clock, MapPin, ChevronRight, Mic, Users } from "lucide-react";

type ScheduleItem = {
  title: string;
  time?: string;
  place?: string;
  speaker?: string;
  description?: string;
  
  action?: {
    label: string;
    url: string;
  };

  // 再帰構造：子要素もまたScheduleItem型
  children?: ScheduleItem[];
};

// スケジュールデータ（内容は元のテキストを維持し、idをaction形式に変換）
const schedule: ScheduleItem[] = [
  {
    time: "12:30",
    title: "開会式",
  },
  {
    time: "12:40",
    title: "全体発表",
    description: "ここに説明を入れる",
    children: [
      {
        title: "タイトル",
        speaker: "○○チーム",
        action: { label: "詳細", url: "/presentations/id_1" }
      },
      {
        title: "タイトル",
        speaker: "情報科○部○組 ○○",
        action: { label: "詳細", url: "/presentations/id_2" }
      },
      {
        title: "タイトル",
        speaker: "情報科○部○組 ○○",
        action: { label: "詳細", url: "/presentations/id_3" }
      },
      {
        title: "タイトル",
        speaker: "情報科○部○組 ○○",
        action: { label: "詳細", url: "/presentations/id_4" }
      }
    ]
  },
  {
    time: "14:00",
    title: "ポスター発表",
    description: "ここに説明を入れる",
    // 親アイテム自体にリンクを持たせるパターン
    action: {
      label: "フロアマップを見る",
      url: "/posters"
    }
  },
  {
    time: "14:50",
    title: "閉会式",
  }
];
---

<Layout title="タイムテーブル">
  <main class="min-h-screen bg-slate-50 py-8 px-4">
    <div class="max-w-md mx-auto mb-10 text-center space-y-3">
      <h1 class="text-2xl font-bold text-slate-900 leading-tight">
        新宿山吹高校<br>情報科発表会
      </h1>
      
      <div class="inline-flex flex-col items-center gap-1 text-sm text-slate-600 bg-white px-6 py-3 rounded-xl border border-slate-200 shadow-sm">
        <div class="font-medium text-lg text-slate-800">2026.03.13 (Fri)</div>
        <div class="flex items-center gap-3 text-xs sm:text-sm mt-1">
          <span class="flex items-center">
            <Clock className="w-3 h-3 mr-1" />
            12:00 受付開始
          </span>
          <span class="w-px h-3 bg-slate-300"></span>
          <span class="flex items-center font-medium text-blue-600">
            <MapPin className="w-3 h-3 mr-1" />
            大講義室
          </span>
        </div>
      </div>
    </div>

    <div class="max-w-md mx-auto space-y-6">
      
      {schedule.map((item) => (
        <div class="relative pl-6 border-l-2 border-slate-200 last:border-0 pb-2">
          {/* 親の時間がある場合のみタイムラインを表示 */}
          {item.time && (
            <>
              <div class="absolute -left-2.25 top-0 w-4 h-4 rounded-full bg-slate-400 border-2 border-white z-10"></div>
              <div class="flex items-center text-sm font-bold text-slate-500 mb-2">
                <Clock className="w-3 h-3 mr-1" />
                {item.time}
              </div>
            </>
          )}

          {/* コンテンツカード */}
          <div class="bg-white rounded-lg border border-slate-200 shadow-sm overflow-hidden">
            
            {/* --- 親要素エリア --- */}
            <div class="p-4 pb-3">
              
              {/* 場所バッジ (データにある場合のみ) */}
              {item.place && (
                <div class="inline-flex items-center text-xs text-blue-600 font-bold bg-blue-50 px-2 py-1 rounded mb-2">
                  <MapPin className="w-3 h-3 mr-1" />
                  {item.place}
                </div>
              )}

              {/* タイトル */}
              <h2 class="text-lg font-bold text-slate-800 leading-snug">
                {item.title}
              </h2>
              
              {/* 発表者（親要素にある場合） */}
              {item.speaker && (
                <p class="text-sm text-slate-600 mt-1 flex items-center">
                  <Mic className="w-3 h-3 mr-1" />
                  {item.speaker}
                </p>
              )}

              {/* 説明文 */}
              {item.description && (
                <p class="text-xs text-slate-500 mt-1">
                  {item.description}
                </p>
              )}

              {/* 親要素のアクションボタン */}
              {item.action && (
                <div class="mt-3">
                  <Button size="sm" className="w-full bg-blue-600 hover:bg-blue-700" asChild>
                    <a href={item.action.url}>
                      {item.action.label} <Users className="w-4 h-4 ml-1" />
                    </a>
                  </Button>
                </div>
              )}
            </div>

            {/* --- 子要素エリア（再帰的なリスト表示） --- */}
            {item.children && (
              <div class="border-t border-slate-100 bg-slate-50/50">
                {item.children.map((child) => (
                  <div class="p-4 border-b border-slate-100 last:border-0 hover:bg-slate-50 transition-colors">
                    
                    {/* 子タイトル */}
                    <h3 class="font-bold text-slate-800 text-sm mb-1">
                      {child.title}
                    </h3>

                    {/* 子発表者 */}
                    {child.speaker && (
                      <p class="text-xs text-slate-600 mb-2 flex items-center">
                        <Mic className="w-3 h-3 mr-1" />
                        {child.speaker}
                      </p>
                    )}

                    {/* 子アクションボタン */}
                    {child.action && (
                      <Button variant="outline" size="sm" className="w-full h-8 text-xs bg-white mt-1" asChild>
                        <a href={child.action.url}>
                          {child.action.label} <ChevronRight className="w-3 h-3 ml-1" />
                        </a>
                      </Button>
                    )}
                  </div>
                ))}
              </div>
            )}

          </div>
        </div>
      ))}

    </div>
  </main>
</Layout>