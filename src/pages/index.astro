---
import Layout from '@/layouts/Layout.astro';
import { Button } from "@/components/ui/button";
import { Badge } from "@/components/ui/badge";
import { Clock, MapPin, ChevronRight, Mic, Users } from "lucide-react";

// タイムテーブルのデータ（後でCMSや別ファイルに分離できます）
const schedule = [
  {
    time: "09:30 - 09:45",
    title: "開会式",
    type: "ceremony", // 式典
    place: "大ホール"
  },
  {
    time: "09:45 - 10:15",
    title: "情報科における生成AIの活用",
    speaker: "3年次 Aさん",
    type: "presentation", // 全体発表
    id: "ai-usage", // 詳細ページのファイル名に対応させる予定
    place: "大ホール"
  },
  {
    time: "10:30 - 11:30",
    title: "ポスターセッション",
    description: "体育館にて各ブースでの発表を行います。",
    type: "poster", // ポスター発表
    place: "体育館"
  },
  {
    time: "13:00 - 13:30",
    title: "Webデザインのトレンド分析",
    speaker: "2年次 Bチーム",
    type: "presentation",
    id: "web-design",
    place: "大ホール"
  },
  {
    time: "15:00",
    title: "閉会式",
    type: "ceremony",
    place: "大ホール"
  }
];
---

<Layout title="タイムテーブル">
  <main class="min-h-screen bg-slate-50 py-8 px-4">
    <div class="max-w-md mx-auto mb-8 text-center space-y-2">
      <h1 class="text-2xl font-bold text-slate-900">新宿山吹高校<br>情報科発表会</h1>
      <p class="text-slate-500 text-sm">2026.02.XX (Sat)</p>
    </div>

    <div class="max-w-md mx-auto space-y-4">
      
      {schedule.map((item) => (
        <div class="relative pl-6 pb-2 border-l-2 border-slate-200 last:border-0">
          <div class="absolute -left-2.25 top-0 w-4 h-4 rounded-full bg-slate-400 border-2 border-white"></div>
          
          <div class="flex items-center text-sm text-slate-500 mb-1">
            <Clock className="w-3 h-3 mr-1" />
            {item.time}
          </div>

          <div class="bg-white rounded-lg border border-slate-200 shadow-sm p-4 hover:shadow-md transition-shadow">
            
            <div class="flex justify-between items-start mb-2">
              <Badge variant={item.type === 'poster' ? "default" : "secondary"} className="text-xs">
                {item.type === 'poster' ? 'ポスター' : item.type === 'presentation' ? '全体発表' : 'その他'}
              </Badge>
              <div class="flex items-center text-xs text-slate-400">
                <MapPin className="w-3 h-3 mr-1" />
                {item.place}
              </div>
            </div>

            <h2 class="text-lg font-bold text-slate-800 mb-1 leading-snug">
              {item.title}
            </h2>

            {/* 発表者名があれば表示 */}
            {item.speaker && (
              <p class="text-sm text-slate-600 mb-3 flex items-center">
                <Mic className="w-3 h-3 mr-1" />
                {item.speaker}
              </p>
            )}

            {/* ポスターセッションの説明 */}
            {item.description && (
              <p class="text-sm text-slate-600 mb-3">
                {item.description}
              </p>
            )}

            {item.type === 'presentation' && (
              <Button variant="outline" size="sm" className="w-full mt-2" asChild>
                <a href={`/presentations/${item.id}`}>
                  詳細を見る <ChevronRight className="w-4 h-4 ml-1" />
                </a>
              </Button>
            )}

            {item.type === 'poster' && (
              <Button size="sm" className="w-full mt-2 bg-blue-600 hover:bg-blue-700" asChild>
                <a href="/posters">
                  会場マップ・一覧を見る <Users className="w-4 h-4 ml-1" />
                </a>
              </Button>
            )}

          </div>
        </div>
      ))}

    </div>
  </main>
</Layout>